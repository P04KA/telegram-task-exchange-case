{
  admin off
  http_port 8081
}

{$PUBLIC_HOST}, :8081 {
  encode gzip zstd

  @api path /api/*
  handle @api {
    reverse_proxy api:3000
  }

  @adminRoot path /admin
  redir @adminRoot /admin/ 308

  handle_path /admin/* {
    root * /srv/admin
    try_files {path} /index.html
    file_server
  }

  handle {
    root * /srv/mini
    try_files {path} /index.html
    file_server
  }
}
