FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/mini-app/package.json apps/mini-app/package.json
COPY apps/admin/package.json apps/admin/package.json

RUN npm ci

FROM deps AS builder
WORKDIR /app

COPY tsconfig.base.json ./
COPY apps ./apps

ARG VITE_API_URL=/api
ENV VITE_API_URL=${VITE_API_URL}
ARG MINI_APP_BASE=/
ENV MINI_APP_BASE=${MINI_APP_BASE}
ARG ADMIN_APP_BASE=/admin/
ENV VITE_APP_BASE=${ADMIN_APP_BASE}

RUN npm run build --workspace @task-exchange/mini-app
RUN npm run build --workspace @task-exchange/admin

FROM caddy:2.10-alpine AS runtime

COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=builder /app/apps/mini-app/dist /srv/mini
COPY --from=builder /app/apps/admin/dist /srv/admin

EXPOSE 443
EXPOSE 8081
